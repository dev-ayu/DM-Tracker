# ══════════════════════════════════════════════
#  ReachMate — Environment Variables
# ══════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# These are also set as Environment Variables in Vercel.

# Your Supabase project URL (Settings → API → Project URL)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Your Supabase anon/public key (Settings → API → anon public)
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key-here

# Supabase service role key (Settings → API → service_role secret) — server-side only
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Groq API key for DM opener generation (https://console.groq.com/keys)
GROQ_API_KEY=gsk_...your-groq-key
